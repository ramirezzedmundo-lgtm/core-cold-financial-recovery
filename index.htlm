<!DOCTYPE html>
<html lang="es">
<head>
    <style>
        body { background: #020202; color: #00ff88; font-family: 'Courier New', monospace; margin: 0; overflow: hidden; }
        #canvas-container { position: relative; width: 100vw; height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center; }
        
        /* Círculo de Carga Industrial */
        .radar { width: 300px; height: 300px; border: 2px solid #004422; border-radius: 50%; position: absolute; animation: pulse 2s infinite; }
        @keyframes pulse { 0% { transform: scale(1); opacity: 1; } 100% { transform: scale(1.5); opacity: 0; } }

        .data-stream { font-size: 0.8rem; color: #004422; position: absolute; width: 100%; text-align: center; bottom: 10%; }
        
        .recovery-value { font-size: 6rem; font-weight: 900; text-shadow: 0 0 20px #00ff88; z-index: 10; }
        .label { font-size: 1.2rem; letter-spacing: 5px; color: #fff; margin-bottom: 20px; }
    </style>
</head>
<body>
    <div id="canvas-container">
        <div class="radar"></div>
        <div class="label">RECONSTRUYENDO ACTIVOS</div>
        <div class="recovery-value" id="count">$0.0</div>
        <div class="data-stream" id="stream">INICIANDO PROTOCOLO ZERO TRUST...</div>
    </div>

    <script>
        const target = 29.4;
        let current = 0;
        const valEl = document.getElementById('count');
        const streamEl = document.getElementById('stream');

        const logs = [
            "Analizando Robo Hormiga...",
            "Detectando fugas por caducidad...",
            "Corrigiendo errores operativos...",
            "Sincronizando con CORE-COLD Engine...",
            "Blindando recuperación industrial..."
        ];

        let logIdx = 0;
        setInterval(() => {
            streamEl.innerText = logs[logIdx % logs.length];
            logIdx++;
        }, 1500);

        const counter = setInterval(() => {
            current += 0.3;
            if (current >= target) {
                valEl.innerText = "$" + target + "M";
                clearInterval(counter);
                streamEl.innerText = "RECUPERACIÓN CONSOLIDADA CON ÉXITO";
                streamEl.style.color = "#fff";
            } else {
                valEl.innerText = "$" + current.toFixed(1) + "M";
            }
        }, 50);
    </script>
</body>
</html>
