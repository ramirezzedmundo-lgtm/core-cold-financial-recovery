<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>CORE-COLD | Panel de Recuperación</title>
    <link rel="stylesheet" href="estilos.css">
</head>
<body>
    <div class="main-viewport">
        <div class="content-box">
            <header class="header-minimal">
                <h1>CORE-COLD FINANCIAL RECOVERY</h1>
                <p>MÉXICO - DIVISIÓN RETAIL E INDUSTRIAL</p>
            </header>

            <table class="data-table">
                <thead>
                    <tr>
                        <th>CONCEPTO DE PÉRDIDA</th>
                        <th>MONTO ACTUAL</th>
                        <th>RECUPERACIÓN ESTIMADA</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Robo Hormiga</td>
                        <td>$12,000,000</td>
                        <td class="positive" data-target="8400000">+$0</td>
                    </tr>
                    <tr>
                        <td>Caducidad de Producto</td>
                        <td>$20,000,000</td>
                        <td class="positive" data-target="12000000">+$0</td>
                    </tr>
                    <tr>
                        <td>Errores Operativos</td>
                        <td>$18,000,000</td>
                        <td class="positive" data-target="9000000">+$0</td>
                    </tr>
                </tbody>
                <tfoot>
                    <tr class="total-row">
                        <td>VALOR TOTAL RECUPERADO</td>
                        <td>$50,000,000</td>
                        <td class="final-sum" data-target="29400000">$0</td>
                    </tr>
                </tfoot>
            </table>

            <footer class="footer-minimal">
                <p>Arquitecto de Sistemas: Edmundo Ramírez</p>
                <p>Origen de Desarrollo: Xbox Environment | Zero Trust Protocol</p>
            </footer>
        </div>
    </div>

    <script>
        // MOTOR DE AUDITORÍA EN TIEMPO REAL
        const formatMoney = (val) => '$' + Math.floor(val).toLocaleString();

        const animateNumbers = () => {
            const elements = document.querySelectorAll('.positive, .final-sum');
            
            elements.forEach(el => {
                const target = parseInt(el.getAttribute('data-target'));
                let current = 0;
                const increment = target / 50; // Velocidad de la carga

                const update = setInterval(() => {
                    current += increment;
                    if (current >= target) {
                        el.innerText = (el.classList.contains('positive') ? '+' : '') + formatMoney(target);
                        clearInterval(update);
                    } else {
                        el.innerText = (el.classList.contains('positive') ? '+' : '') + formatMoney(current);
                    }
                }, 30);
            });
        };

        window.onload = animateNumbers;
    </script>
</body>
</html>
